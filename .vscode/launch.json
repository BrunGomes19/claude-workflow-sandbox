    {
      "name": "Radar: CYCLE_MAP_BUILD (dry-run)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/radar_export.py",
      "args": [
        "--run-mode",
        "CYCLE_MAP_BUILD",
        "--dry-run"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
